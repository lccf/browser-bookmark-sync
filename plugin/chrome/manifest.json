{
  "manifest_version": 3,
  "name": "书签同步",
  "version": "1.0.0",
  "description": "同步浏览器书签到服务端",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
